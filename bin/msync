#!/usr/bin/env python3

import os
import sys

# pop the first argument, which is the script name
args = sys.argv
cmd = args.pop(0)
ops = args.pop(0)
src = args.pop(0)

cmds = []
for dst in args:
    line = 'rsync --exclude=.ccls-cache {} {} {}'.format(ops, src, dst)
    cmds.append(line)

line = ' & '.join(cmds)
print(line)
os.system(line)
